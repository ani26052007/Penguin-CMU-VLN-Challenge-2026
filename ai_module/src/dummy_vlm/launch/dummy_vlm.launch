<launch>

  <node pkg="dummy_vlm" exec="dummyVLM" name="dummyVLM" output="screen">
    <param name="question_file_dir" value="$(find-pkg-share dummy_vlm)/data/question.txt" />
    <param name="waypoint_file_dir" value="$(find-pkg-share dummy_vlm)/data/waypoints.ply" />
    <param name="object_list_file_dir" value="$(find-pkg-share dummy_vlm)/data/object_list.txt" />
    <param name="waypointReachDis" value="1.0" />
  </node>

</launch>
